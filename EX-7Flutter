          SizedBox(height:10),
          travelImage(
              "https://upload.wikimedia.org/wikipedia/commons/d/da/Taj-Mahal.jpg"
          ),
          travelImage(
"https://upload.wikimedia.org/wikipedia/commons/a/a8/Tour_Eiffel_Wikimedia_Commons.jpg"
