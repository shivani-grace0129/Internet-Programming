  }
  Widget profileStat(String number,String label){
    return Column(
      children: [
        Text(number,style:TextStyle(fontSize:22,fontWeight:FontWeight.bold)),
        Text(label)
      ],
    );
  }
  Widget travelImage(String url){
    return Padding(
      padding: EdgeInsets.all(10),
      child: ClipRRect(
        borderRadius: BorderRadius.circular(15),
        child: Image.network(url,height:200,width:double.infinity,fit:BoxFit.cover),
      ),
    );
  }
}

